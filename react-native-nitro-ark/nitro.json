{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitroark"
  ],
  "ios": {
    "iosModuleName": "NitroArk"
  },
  "android": {
    "androidNamespace": [
      "nitroark"
    ],
    "androidCxxLibName": "NitroArk"
  },
  "autolinking": {
    "NitroArk": {
      "all": {
        "language": "c++",
        "implementationClassName": "NitroArk"
      }
    }
  },
  "ignorePaths": [
    "node_modules"
  ]
}
